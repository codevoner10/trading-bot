# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Upstash Redis
REDIS_URL=rediss://default:password@host.upstash.io:6379

# Worker config
WORKER_ID=Worker_A
HEARTBEAT_INTERVAL=60
CLAIM_TIMEOUT=300
MAX_RUNTIME_MINUTES=330

# Alerts (Discord/Slack webhook)
ALERT_WEBHOOK=https://discord.com/api/webhooks/xxx/xxx